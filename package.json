{
  "name": "ghostwheel",
  "version": "1.0.0",
  "description": "jekyll and css modules in perfect harmony",
  "main": "index.js",
  "lanyon": {
    "entries": [
      "app"
    ]
  },
  "scripts": {
    "clean": "rm -rf _site",
    "start": "webpack"
  },
  "stylelint": {
    "syntax": "scss",
    "extends": "stylelint-config-standard",
    "plugins": [
      "stylelint-scss"
    ],
    "rules": {
      "property-no-unknown": [
        true,
        {
          "ignoreProperties": [
            "//"
          ]
        }
      ],
      "no-invalid-double-slash-comments": null,
      "selector-pseudo-class-no-unknown": [
        true,
        {
          "ignorePseudoClasses": [
            "global"
          ]
        }
      ]
    }
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "babel-core": "^6.26.0",
    "babel-eslint": "^8.0.0",
    "babel-jest": "^21.0.2",
    "babel-loader": "^7.1.2",
    "babel-preset-env": "^1.6.0",
    "babel-register": "^6.26.0",
    "browser-sync": "^2.18.13",
    "eslint": "^4.7.2",
    "eslint-plugin-babel": "^4.1.2",
    "eslint-plugin-react": "^7.3.0",
    "stylelint": "^8.1.1",
    "stylelint-config-standard": "^17.0.0",
    "stylelint-scss": "^2.1.0"
  }
}
